<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        tools:context=".MainActivity">

    <!-- Header App Title -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Offline Whisper Recorder"
        android:textColor="#F8FAFC"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.03"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Status Capsule -->
    <LinearLayout
        android:id="@+id/statusContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@android:drawable/toast_frame"
        android:backgroundTint="#1E293B"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle">

        <View
            android:id="@+id/statusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="8dp"
            android:background="@android:drawable/presence_online"
            android:backgroundTint="#10B981" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready"
            android:textColor="#E2E8F0"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Group for Recording Screen views -->
    <androidx.constraintlayout.widget.Group
        android:id="@+id/recordingScreenGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:constraint_referenced_ids="timerCard,controlsContainer,aiModeContainer,taskCard,tvTranscriptionHeader,transcriptionCard,resultsContainer" />

    <!-- Group for Cart Screen views -->
    <androidx.constraintlayout.widget.Group
        android:id="@+id/cartScreenGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:constraint_referenced_ids="cartCard,pcConnectionContainer" />

    <!-- Model Download UI (Shown only when model is missing) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/modelDownloadCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI SETUP REQUIRED"
                android:textColor="#F43F5E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Download Gemma Model (2.9 GB)"
                android:textColor="#F1F5F9"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="PharmaCam requires the Gemma model to verify medicine names offline. Select one of the options below to download and set it up."
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:lineSpacingExtra="3sp" />

            <!-- Progress section -->
            <LinearLayout
                android:id="@+id/downloadProgressContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <ProgressBar
                    android:id="@+id/downloadProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progressTint="#3B82F6"
                    android:progressBackgroundTint="#475569"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tvDownloadStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Starting download..."
                    android:textColor="#E2E8F0"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Action buttons -->
            <LinearLayout
                android:id="@+id/downloadActionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadInApp"
                    style="@style/Widget.Material3.Button.ElevatedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Download in App"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#3B82F6"
                    app:cornerRadius="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDownloadLink"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Get Link"
                        android:textColor="#3B82F6"
                        app:strokeColor="#3B82F6"
                        app:cornerRadius="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectModelFile"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Select File"
                        android:textColor="#E2E8F0"
                        app:strokeColor="#475569"
                        app:cornerRadius="10dp" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelAiMode"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:text="Cancel &amp; Use Fuzzy Search"
                    android:textColor="#94A3B8"
                    app:cornerRadius="10dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Confirmed Medicines Cart Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cartCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRMED MEDICINES CART"
                android:textColor="#3B82F6"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <!-- Cart Items RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCartItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#334155"
                android:layout_marginBottom="16dp" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackToRecording"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Back"
                    android:textColor="#94A3B8"
                    app:strokeColor="#475569"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendToPc"
                    android:layout_width="0dp"
                    android:layout_weight="1.2"
                    android:layout_height="wrap_content"
                    android:text="Send to PC"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#22C55E"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Timer Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/timerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="8dp"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECORDING TIME"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="00:00"
                android:textColor="#F1F5F9"
                android:textSize="48sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Control Buttons -->
    <LinearLayout
        android:id="@+id/controlsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/timerCard">

        <!-- Record Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecord"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:layout_marginEnd="12dp"
            android:text="Record"
            android:textColor="#FFFFFF"
            app:backgroundTint="#EF4444"
            app:cornerRadius="30dp"
            app:elevation="4dp" />

        <!-- Stop Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:layout_marginEnd="12dp"
            android:enabled="false"
            android:text="Stop"
            android:textColor="#FFFFFF"
            app:backgroundTint="#3B82F6"
            app:cornerRadius="30dp"
            app:elevation="4dp" />

        <!-- Clear Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:text="Clear"
            android:textColor="#94A3B8"
            app:strokeColor="#475569"
            app:cornerRadius="30dp" />

    </LinearLayout>

    <!-- AI Mode Toggle Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/aiModeContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginHorizontal="0dp"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/controlsContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="14dp"
            android:paddingVertical="12dp">

            <!-- Mode icon dot -->
            <View
                android:id="@+id/aiModeDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="10dp"
                android:background="@android:drawable/presence_online"
                android:backgroundTint="#475569" />

            <TextView
                android:id="@+id/tvAiModeLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AI Mode (Gemma)"
                android:textColor="#CBD5E1"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAiModeStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="OFF"
                android:textColor="#475569"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAiMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:text="" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- PC Server Connection Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/pcConnectionContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginHorizontal="0dp"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cartCard"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <!-- Connection status dot -->
                <View
                    android:id="@+id/pcStatusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@android:drawable/presence_online"
                    android:backgroundTint="#EF4444" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="PC Server Connection"
                    android:textColor="#CBD5E1"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPcConnectionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DISCONNECTED"
                    android:textColor="#EF4444"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilServerIp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_weight="3"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:hint="PC Server IP"
                    app:hintTextColor="#64748B"
                    app:boxStrokeColor="#475569"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:boxBackgroundColor="#1E293B"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etServerIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:textColor="#E2E8F0"
                        android:textSize="14sp"
                        android:singleLine="true"
                        android:textCursorDrawable="@null" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilServerPort"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_weight="1.5"
                    android:layout_height="wrap_content"
                    android:hint="Port"
                    app:hintTextColor="#64748B"
                    app:boxStrokeColor="#475569"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:boxBackgroundColor="#1E293B"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etServerPort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="#E2E8F0"
                        android:textSize="14sp"
                        android:singleLine="true"
                        android:textCursorDrawable="@null" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#334155"
                android:layout_marginVertical="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PC Typing Format (Drag to Reorder)"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFormatTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:scrollbars="none" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Tap tag to remove. Add available tags below:"
                    android:textColor="#64748B"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvResetFormat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESET DEFAULT"
                    android:textColor="#3B82F6"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground" />
            </LinearLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgAvailableTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="6dp"
                app:chipSpacingVertical="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Background Task Displayer -->
    <androidx.cardview.widget.CardView
        android:id="@+id/taskCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="8dp"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/aiModeContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE BACKGROUND PROCESSES"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <LinearLayout
                android:id="@+id/tasksListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNoTasks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No active background processes (Idle)"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Transcription Box Header -->
    <TextView
        android:id="@+id/tvTranscriptionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="TRANSCRIPTION RESULT"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/taskCard" />

    <!-- Transcription Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/transcriptionCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTranscriptionHeader">

        <FrameLayout
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTranscription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your transcription will appear here after you stop recording..."
                android:textColor="#CBD5E1"
                android:textSize="16sp"
                android:lineSpacingExtra="6sp" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Results Container (Single dynamic section) -->
    <LinearLayout
        android:id="@+id/resultsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/transcriptionCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Dynamic section header — changes between FUZZY MATCH and GEMMA RESULT -->
            <TextView
                android:id="@+id/tvResultSectionHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FUZZY MATCH"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="12dp"
                android:text="CONFIRM"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:visibility="gone"
                app:backgroundTint="#22C55E"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Selection List (Used for Fuzzy/Hybrid mode) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSelections"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:padding="8dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

                <!-- Text display (Used for Gemma or simple results) -->
                <FrameLayout
                    android:id="@+id/resultScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tvFinalMedicine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fuzzy match result will appear here..."
                        android:textColor="#CBD5E1"
                        android:textSize="16sp"
                        android:lineSpacingExtra="6sp" />
                </FrameLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>